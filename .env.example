# Copy this file to .env.local and fill in your BoardGameGeek app token.
# .env.local is git-ignored so the token never gets committed.
#
# Get a token: register a (free, non-commercial) application at
# https://boardgamegeek.com/applications then create a token for it.
# See BGG_SETUP.md for the full steps.

EXPO_PUBLIC_BGG_TOKEN=
